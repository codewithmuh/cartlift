# Cartlift — local dev env. Copy to .env and adjust.

DJANGO_SECRET_KEY=please-rotate-this-in-prod
DJANGO_DEBUG=1

# Optional — server-side only. If unset, the audit endpoint returns
# canned findings so the demo flow still works offline.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional — dogfood the snippet on the marketing site itself. When both
# are set, the public site loads /s/<token>.js from the API and runs Cartlift's
# own A/B tests on its own pages. Leave blank in local dev.
# (Kept on the BANDIT_* prefix to match the customer-facing window.bandit global
# and the bnd_xxx snippet tokens, which are intentionally stable across rebrands.)
NEXT_PUBLIC_BANDIT_API_BASE=
NEXT_PUBLIC_BANDIT_TOKEN=

# Postgres
POSTGRES_DB=cartlift
POSTGRES_USER=cartlift
POSTGRES_PASSWORD=cartlift_dev

# First-boot superuser (login at http://localhost:8050/admin)
DJANGO_SUPERUSER_EMAIL=admin@cartlift.codewithmuh.com
DJANGO_SUPERUSER_PASSWORD=cartlift_admin_dev

# Allocator scheduler — the `scheduler` compose service re-runs Thompson
# sampling on this interval (seconds). 1800 = 30 min matches the README.
# Drop to e.g. 60 in dev to watch the weight-history chart move in near-real-time.
BANDIT_ALLOCATOR_INTERVAL=1800
