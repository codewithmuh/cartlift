{
  "version": 2,
  "builds": [
    {
      "src": "conf/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "conf/wsgi.py"
    }
  ],
  "crons": [
    {
      "path": "/api/admin/run-allocator",
      "schedule": "17 3 * * *"
    }
  ]
}
